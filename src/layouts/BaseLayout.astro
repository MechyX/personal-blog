---
import "../styles/global.css";
import "katex/dist/katex.min.css";
import { isCurrentRoute, relativeHref } from "../lib/url";

interface Props {
  title?: string;
  description?: string;
}

const siteTitle = "Rithesh";
const { title = siteTitle, description = "Personal site of Rithesh." } = Astro.props;
const pageTitle = title === siteTitle ? title : `${title} - ${siteTitle}`;
const pathname = Astro.url.pathname;
const isTechRoute = ["/", "/tech/"].some((route) => isCurrentRoute(pathname, route)) || pathname.startsWith("/posts/");
const isNonTechRoute = isCurrentRoute(pathname, "/not-tech/");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="alternate" type="application/rss+xml" title="Tech RSS Feed" href="/tech/feed.xml" />
    <link rel="alternate" type="application/rss+xml" title="Not Tech RSS Feed" href="/not-tech/feed.xml" />
    <title>{pageTitle}</title>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-83Z2S74VEV"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-83Z2S74VEV');
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-title">Rithesh</div>

        <nav class="site-nav" aria-label="primary">
          <a href={relativeHref(pathname, "/tech/")} aria-current={isTechRoute ? "page" : undefined}>tech</a>
          <a href={relativeHref(pathname, "/not-tech/")} aria-current={isNonTechRoute ? "page" : undefined}>not tech</a>
          <a href={relativeHref(pathname, "/about/")} aria-current={isCurrentRoute(pathname, "/about/") ? "page" : undefined}>about</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
