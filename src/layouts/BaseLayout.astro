---
import "../styles/global.css";
import { pathWithBase } from "../lib/url";

interface Props {
  title?: string;
  description?: string;
}

const siteTitle = "Rithesh";
const { title = siteTitle, description = "Notes on software, systems, and writing." } = Astro.props;
const pageTitle = title === siteTitle ? title : `${title} - ${siteTitle}`;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-title">Rithesh</div>

        <nav class="site-nav" aria-label="primary">
          <a href={pathWithBase("/")} aria-current={pathname === pathWithBase("/") ? "page" : undefined}>posts</a>
          <a href={pathWithBase("/about/")} aria-current={pathname === pathWithBase("/about/") ? "page" : undefined}>about</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
