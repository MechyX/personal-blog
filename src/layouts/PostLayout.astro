---
import BaseLayout from "./BaseLayout.astro";
import { formatPostDate } from "../lib/posts";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  image?: string;
}

const { title, description, pubDate, image } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-header">
      <h1>{title}</h1>
      <time datetime={pubDate.toISOString()}>{formatPostDate(pubDate)}</time>
    </header>

    {image && <img class="post-hero" src={image} alt="" />}

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
