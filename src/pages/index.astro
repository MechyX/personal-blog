---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatPostDate, getPostSlug, getPublishedPosts } from "../lib/posts";
import { relativeHref } from "../lib/url";

const posts = await getPublishedPosts();
const pathname = Astro.url.pathname;
---

<BaseLayout>
  <section class="post-list" aria-label="posts">
    {posts.map((post) => (
      <a class="post-row" href={relativeHref(pathname, `/posts/${getPostSlug(post.id)}/`)}>
        <time datetime={post.data.pubDate.toISOString()}>{formatPostDate(post.data.pubDate)}</time>
        <span>{post.data.title}</span>
      </a>
    ))}
  </section>
</BaseLayout>
