---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";
import { getPublishedPosts } from "../lib/posts";
import { postSections } from "../lib/postSections";

const posts = await getPublishedPosts();
const pathname = Astro.url.pathname;
const defaultSection = postSections[0];
const sectionPosts = posts.filter((post) => post.data.section === defaultSection.id);
---

<BaseLayout>
  <section class="post-section" aria-label={`${defaultSection.title} posts`}>
    <PostList posts={sectionPosts} pathname={pathname} />
  </section>
</BaseLayout>
